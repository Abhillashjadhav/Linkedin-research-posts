#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
if [ -x "$ROOT/.venv/bin/python" ]; then
  PYTHON="$ROOT/.venv/bin/python"
else
  PYTHON="${PYTHON:-python3}"
fi

MODULE="authority_os.quality_cli"
for ARG in "$@"; do
  if [ "$ARG" = "--dry-run" ]; then
    # Preserve the complete deterministic fixture diagnostics used by public
    # smoke tests. High-bar suppression applies only to live model drafting.
    MODULE="authority_os"
    break
  fi
done

PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}" exec "$PYTHON" -m "$MODULE" "$@"
